/* ===== CONTACT SECTION ===== */

#contact{
  padding:80px 40px;
  background:#f8fafc;
}
.stag{text-align: center; margin: 0 auto 12px;}
.stitle{text-align: center; color: #1e293b;}
.ssub{text-align: center; color:#64748b; max-width: 600px; margin: 12px auto 0;}
.ct-grid{
  max-width:1200px;
  margin:40px auto 0;
}

/* ===== MOBILE = 1 colonne - Garde le rendu de tes photos ===== */
.contact-info,
.cform{
  width:100%;
}

/* ===== DESKTOP = 2 colonnes ===== */
@media (min-width:993px){
  .ct-grid{
    display:grid;
    grid-template-columns: 1fr 1.2fr;
    gap:48px;
    align-items:start;
  }

  /* Colonne gauche : Infos contact */
  .contact-info{
    position:sticky;
    top:100px;
  }

  .contact-info h3{
    font-size:28px;
    font-weight:700;
    color:#1e293b;
    margin-bottom:12px;
  }
  
  .contact-info .ct-p{
    color:#64748b;
    margin-bottom:32px;
    line-height:1.6;
  }

  .c-det-item{
    display:flex;
    gap:16px;
    align-items:flex-start;
    margin-bottom:24px;
  }
  
  .c-det-ic{
    width:48px;
    height:48px;
    border-radius:12px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    font-size:18px;
    flex-shrink:0;
  }
  .c-det-ic.phone{background:#2563eb;}
  .c-det-ic.email{background:#0d9488;}
  .c-det-ic.location{background:#f59e0b;}
  .c-det-ic.whatsapp{background:#22c55e;}

  .c-det-item strong{
    display:block;
    font-size:12px;
    color:#64748b;
    letter-spacing:0.5px;
    margin-bottom:4px;
    text-transform:uppercase;
  }
  .c-det-item span, .c-det-item a{
    font-size:15px;
    color:#1e293b;
    font-weight:600;
    text-decoration:none;
  }

  .social-row{
    margin-top:32px;
  }
  .social-row > span{
    display:block;
    font-size:12px;
    color:#64748b;
    letter-spacing:0.5px;
    margin-bottom:12px;
    text-transform:uppercase;
  }
  .social-icons{
    display:flex;
    gap:12px;
  }
  .social-icons a{
    width:40px;
    height:40px;
    border-radius:50%;
    background:#e2e8f0;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#475569;
    transition:0.3s;
  }
  .social-icons a:hover{
    background:#2563eb;
    color:white;
    transform:translateY(-3px);
  }

  /* Colonne droite : Disponibilité + Formulaire */
  .availability-card{
    background:white;
    padding:24px;
    border-radius:16px;
    box-shadow:0 4px 20px rgba(0,0,0,0.06);
    margin-bottom:24px;
  }
  .availability-card h3{
    display:flex;
    align-items:center;
    gap:10px;
    font-size:18px;
    margin-bottom:16px;
    color:#1e293b;
  }
  .avail-row{
    display:flex;
    justify-content:space-between;
    padding:12px 0;
    border-bottom:1px solid #f1f5f9;
    font-size:15px;
  }
  .avail-row:last-child{
    border-bottom:none;
  }
  .avail-row.urgent span:last-child{
    color:#0d9488;
    font-weight:600;
  }

  .form-card{
    background:white;
    padding:32px;
    border-radius:16px;
    box-shadow:0 4px 20px rgba(0,0,0,0.06);
  }

  .form-header{
    display:flex;
    gap:16px;
    margin-bottom:24px;
  }
  .form-icon{
    width:56px;
    height:56px;
    border-radius:16px;
    background:linear-gradient(135deg,#2563eb,#0d9488);
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    font-size:24px;
    flex-shrink:0;
  }
  .form-header h3{
    font-size:22px;
    margin-bottom:4px;
    color:#1e293b;
  }
  .form-header p{
    color:#64748b;
    font-size:14px;
  }

  /* Formulaire en 2 colonnes sur desktop */
  .f-row{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
  }
  
  .fg label{
    display:block;
    font-size:14px;
    font-weight:600;
    margin-bottom:8px;
    color:#1e293b;
  }
  
  .input-wrap{
    display:flex;
    align-items:center;
    gap:12px;
    border:1px solid #e2e8f0;
    border-radius:12px;
    padding:12px 16px;
    background:white;
    transition:0.2s;
  }
  .input-wrap:focus-within{
    border-color:#2563eb;
    box-shadow:0 0 0 3px rgba(37,99,235,0.1);
  }
  .input-wrap i{
    color:#94a3b8;
  }
  .input-wrap input, 
  .input-wrap select, 
  .input-wrap textarea{
    border:none;
    outline:none;
    width:100%;
    font-size:15px;
    background:transparent;
    font-family:inherit;
  }
  .input-wrap textarea{
    min-height:120px;
    resize:vertical;
  }

  .f-sub{
    width:100%;
    padding:14px;
    background:linear-gradient(135deg,#2563eb,#0d9488);
    color:white;
    border:none;
    border-radius:12px;
    font-weight:600;
    font-size:16px;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    margin-top:8px;
    transition:0.3s;
  }
  .f-sub:hover{
    transform:translateY(-2px);
    box-shadow:0 8px 20px rgba(37,99,235,0.3);
  }
}

/* ===== MOBILE ===== */
@media (max-width:992px){
  #contact{
    padding:60px 20px;
  }
  
  .f-row{
    display:block;
  }
  
  .fg{
    margin-bottom:16px;
  }
}

